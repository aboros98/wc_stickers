# --- Frontend (Vite) — these are PUBLIC and safe to ship in the browser bundle ---
# Supabase project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=
# Supabase "anon" public key (RLS protects your data; this key is meant to be public)
VITE_SUPABASE_ANON_KEY=

# --- Catalog importer (Node script only — NEVER expose the service role key in the browser) ---
# Same URL as above
SUPABASE_URL=
# Supabase "service_role" secret key (bypasses RLS; used only by supabase/import-catalog.mjs)
SUPABASE_SERVICE_ROLE_KEY=
